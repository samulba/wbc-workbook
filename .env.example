# ──────────────────────────────────────────────────────────────
#  Wellbeing Workbook — Environment Variables
#  Copy to `.env.local` (gitignored) and fill in the real values.
#  For production, set these in Vercel → Project → Settings →
#  Environment Variables.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI ────────────────────────────────────────────────────
# Single key powers both:
#   • /api/analyse-room  → GPT-4o vision  (room photo → KI-Analyse)
#   • /api/render-room   → gpt-image-1    (photo → redesign render)
# Get a key: https://platform.openai.com/api-keys
# Billing:   https://platform.openai.com/account/billing
OPENAI_API_KEY=
