# ──────────────────────────────────────────────────────────────
#  Wellbeing Workbook — Environment Variables
#  Copy to `.env.local` (gitignored) and fill in the real values.
#  For production, set these in Vercel → Project → Settings →
#  Environment Variables.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (Claude Vision) ─────────────────────────────────
# Used by /api/analyse-room for the KI-Raumanalyse (photo → strengths,
# improvement suggestions, recommendations).
# Get a key: https://console.anthropic.com/  →  Settings  →  API Keys
ANTHROPIC_API_KEY=

# ── Stability AI (Stable Diffusion XL img2img) ────────────────
# Used by /api/render-room to turn a user's room photo into a
# redesigned visualization matching their concept.
# Get a key: https://platform.stability.ai/account/keys
STABILITY_API_KEY=
